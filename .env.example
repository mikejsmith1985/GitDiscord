# ── Discord ──────────────────────────────────────────────────────────────────
# Bot token from the Discord Developer Portal (https://discord.com/developers)
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Message Content Intent is privileged in Discord. Keep this false unless you
# have enabled it in the Developer Portal and need NLP mode for plain messages.
ENABLE_MESSAGE_CONTENT_INTENT=false

# ── GitHub Webhooks ───────────────────────────────────────────────────────────
# Secret used to validate incoming GitHub webhook payloads (HMAC-SHA256)
WEBHOOK_SECRET=your-github-webhook-secret-here

# ── GitHub App Auth ────────────────────────────────────────────────────────────
# App credentials used for all GitHub API operations from slash commands.
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GITHUB_APP_INSTALLATION_ID=987654321

# Port the FastAPI webhook receiver listens on
# Railway automatically injects PORT; this value is used for local development
WEBHOOK_PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file
# On Railway with a persistent volume, use /data/gitdiscord.db
DATABASE_PATH=./gitdiscord.db

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
